<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/imgModalFood"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/txtModalName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/txtModalPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="S/ 0.00"
        android:textSize="16sp"
        android:textColor="#FF6B00"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/txtModalDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Descripción"
        android:textSize="14sp"
        android:textColor="#555555"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/txtModalStock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stock: 0"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginTop="4dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnModalAddToCart"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:text="Agregar al carrito"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#FF6B00"
        app:cornerRadius="12dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</LinearLayout>